#pragma once

// ── WiFi ──────────────────────────────────────────────────────────────────────
#define WIFI_SSID       "YourNetworkName"
#define WIFI_PASSWORD   "YourPassword"

// ── Server ────────────────────────────────────────────────────────────────────
#define SERVER_URL      "http://192.168.1.x:7654/api/image"

// ── Poll timing ───────────────────────────────────────────────────────────────
#define DEFAULT_POLL_INTERVAL_SEC   60u    // development default
#define MIN_POLL_INTERVAL_SEC       60u
#define MAX_POLL_INTERVAL_SEC     3600u
#define WIFI_CONNECT_TIMEOUT_MS  10000u
#define HTTP_TIMEOUT_MS           8000u

// ── Battery estimation ────────────────────────────────────────────────────────
#define BATTERY_CAPACITY_MAH  2000u   // rated capacity of your LiPo cell
#define AVG_DISCHARGE_MA         6u   // typical idle + EPD refresh average

// ── AXP2101 (I2C) ────────────────────────────────────────────────────────────
#define AXP_SDA   47
#define AXP_SCL   48
#define AXP_ADDR  0x34

// ── E-paper display (SPI) ────────────────────────────────────────────────────
#define EPD_SCK    10
#define EPD_MOSI   11
#define EPD_CS      9
#define EPD_DC      8
#define EPD_RST    12
#define EPD_BUSY   13
#define EPD_PWR     6

// ── Display geometry ─────────────────────────────────────────────────────────
#define EPD_WIDTH        800
#define EPD_HEIGHT       480
#define EPD_IMAGE_BYTES  192000   // 800 * 480 / 2  (4bpp)
